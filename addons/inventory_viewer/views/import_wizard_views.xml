<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="inventory_import_wizard_form"
            model="ir.ui.view">

        <field name="name">
            inventory.import.wizard.form
        </field>

        <field name="model">
            inventory.import.wizard
        </field>

        <field name="arch" type="xml">

            <form string="Import Inventory">

                <group>

                    <field name="api_url"/>

                </group>

                <footer>

                    <button name="action_import"
                            string="Import"
                            type="object"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"/>

                </footer>

            </form>

        </field>

    </record>

    <record id="inventory_import_action"
            model="ir.actions.act_window">

        <field name="name">
            Import Inventory
        </field>

        <field name="res_model">
            inventory.import.wizard
        </field>

        <field name="view_mode">
            form
        </field>

        <field name="target">
            new
        </field>

    </record>

</odoo>
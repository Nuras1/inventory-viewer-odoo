<?xml version="1.0" encoding="utf-8"?>

<odoo>

<record id="inventory_viewer_list"
        model="ir.ui.view">

    <field name="name">inventory.viewer.list</field>

    <field name="model">inventory.viewer</field>

    <field name="arch" type="xml">

        <list>
            <field name="name"/>
            <field name="category"/>
            <field name="items_count"/>
        </list>

    </field>

</record>

    <record id="inventory_viewer_form"
            model="ir.ui.view">

        <field name="name">inventory.viewer.form</field>

        <field name="model">inventory.viewer</field>

        <field name="arch"
               type="xml">

            <form>

    <sheet>

        <group>

            <field name="name"/>
            <field name="category"/>
            <field name="items_count"/>

        </group>

        <notebook>

            <page string="Fields">

                <field name="field_ids">

                    <list>

                        <field name="name"/>
                        <field name="field_type"/>

                    </list>

                </field>

            </page>

            <page string="Aggregates">

                <field name="aggregate_ids">

                    <list>

                        <field name="field_name"/>
                        <field name="value"/>

                    </list>

                </field>

            </page>

        </notebook>

    </sheet>

</form>

        </field>

    </record>

    <record id="inventory_viewer_action"
            model="ir.actions.act_window">

        <field name="name">Inventories</field>

        <field name="res_model">inventory.viewer</field>

        <field name="view_mode">list,form</field>

    </record>

    <menuitem id="inventory_viewer_root"
              name="Inventory Viewer"/>

    <menuitem id="inventory_viewer_menu"
              parent="inventory_viewer_root"
              action="inventory_viewer_action"
              name="Inventories"/>

    <record id="inventory_import_action"
              model="ir.actions.act_window">

    <field name="name">Import Inventory</field>
    <field name="res_model">inventory.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>

    </record>

<menuitem
    id="inventory_import_menu"
    parent="inventory_viewer_root"
    action="inventory_import_action"
    name="Import Inventory"
    sequence="20"/>
</odoo>
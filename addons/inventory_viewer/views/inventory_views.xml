<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="inventory_viewer_tree"
            model="ir.ui.view">

        <field name="name">
            inventory.viewer.tree
        </field>

        <field name="model">
            inventory.viewer
        </field>

        <field name="arch"
               type="xml">

            <tree>

                <field name="name"/>

                <field name="category"/>

                <field name="items_count"/>

            </tree>

        </field>

    </record>

    <record id="inventory_viewer_form"
            model="ir.ui.view">

        <field name="name">
            inventory.viewer.form
        </field>

        <field name="model">
            inventory.viewer
        </field>

        <field name="arch"
               type="xml">

            <form>

                <sheet>

                    <group>

                        <field name="name"/>

                        <field name="category"/>

                        <field name="items_count"/>

                        <field name="api_token"/>

                    </group>

                </sheet>

            </form>

        </field>

    </record>

    <record id="inventory_viewer_action"
            model="ir.actions.act_window">

        <field name="name">
            Inventories
        </field>

        <field name="res_model">
            inventory.viewer
        </field>

        <field name="view_mode">
            tree,form
        </field>

    </record>

    <menuitem id="inventory_viewer_root"
              name="Inventory Viewer"/>

    <menuitem id="inventory_viewer_menu"
              parent="inventory_viewer_root"
              action="inventory_viewer_action"
              name="Inventories"/>

</odoo>